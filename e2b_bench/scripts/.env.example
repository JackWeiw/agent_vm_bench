# E2B Environment Configuration
# Copy this file and fill in your actual values

# E2B API URL (your local E2B server address)
E2B_API_URL=http://141.61.17.196:3000

# Note: E2B_API_KEY and E2B_ACCESS_TOKEN are read from ~/.e2b/config.json
# You don't need to set them here. The config.json should have:
# {
#   "api_key": "e2b_xxx",
#   "token": "your-access-token"
# }

# Optional: E2B Domain
E2B_DOMAIN=e2b.app

# Optional: HTTP SSL setting
E2B_HTTP_SSL=false